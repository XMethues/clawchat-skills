{
  "name": "personal-account-management-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:select": "node ./scripts/check-select.mjs",
    "check:selectors": "node ./scripts/check-selectors.mjs",
    "check:subscriptions": "node ./scripts/check-subscriptions.mjs",
    "check:theme": "node ./scripts/check-theme.mjs",
    "build": "vite build",
    "prepare": "svelte-kit sync",
    "verify:dist": "node ./scripts/verify-dist.mjs"
  },
  "dependencies": {
    "@lucide/svelte": "1.24.0",
    "bits-ui": "2.18.1",
    "clsx": "2.1.1",
    "mode-watcher": "1.1.0",
    "svelte-sonner": "1.1.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.70.1",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "26.1.1",
    "shadcn-svelte": "1.4.2",
    "svelte": "5.56.4",
    "svelte-check": "4.3.2",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "8.1.4"
  }
}
